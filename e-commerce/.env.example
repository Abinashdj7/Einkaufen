# Copy this file to .env and fill in real values before running docker-compose.
# .env is gitignored - never commit real secrets.

# MySQL root password (used to initialize the database container)
MYSQL_ROOT_PASSWORD=changeme123

# Credentials the Spring Boot server uses to connect to MySQL
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=changeme123

# Long, random string used to sign/verify JWTs (e.g. `openssl rand -base64 64`).
# Rotating this invalidates every issued token.
JWT_SECRET=replace-with-a-long-random-string-generated-via-openssl-rand-base64-64

# Comma separated list of front-end origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Default administrator account provisioned on first startup.
# Leave ADMIN_PASSWORD blank to skip creating an admin account.
ADMIN_EMAIL=admin@nouveau-ecommerce.com
ADMIN_PASSWORD=changeme123

# Razorpay API credentials (use your test-mode keys from the Razorpay dashboard)
RAZORPAY_API_KEY=rzp_test_dummykey1234
RAZORPAY_API_SECRET=dummysecret1234567890
